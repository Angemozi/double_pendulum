# =============================================================================
# .gitignore  --  Double Pendulum RL
# -----------------------------------------------------------------------------
# WHEN TO UPDATE THIS FILE (notice these situations):
#   * You add a NEW build directory name (we assume build*/ ; add others here).
#   * You introduce a NEW dependency manager (vcpkg/conan) -> ignore its caches.
#   * You add a NEW tool that emits artifacts (profilers, sanitizers, coverage).
#   * Generated OUTPUT lands in a new folder (currently models/ and logs/).
#   * You add IDE/editor configs that should stay local, not shared.
#   * A real source file is being ignored by a broad pattern -> add a "!" un-ignore.
# Keep generated/output artifacts OUT of git; keep configs/ and src/ IN.
# =============================================================================

# ---- CMake / build trees ----------------------------------------------------
build/
build-*/
out/
cmake-build-*/          # CLion default build dirs
CMakeCache.txt
CMakeFiles/
CMakeUserPresets.json
cmake_install.cmake
CTestTestfile.cmake
Testing/
_deps/                  # FetchContent (e.g. Dear ImGui) download/build cache
install/

# ---- Compiled objects / libraries / executables -----------------------------
*.o
*.obj
*.lo
*.slo
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.pdb
*.ilk
*.exp

# ---- MSVC / Visual Studio ----------------------------------------------------
.vs/
*.vcxproj.user
*.sln
*.suo
Debug/
Release/
x64/
x86/

# ---- Dependency managers (add as you adopt them) ----------------------------
vcpkg_installed/
.conan/
conan.lock

# ---- Runtime OUTPUT (generated by training/eval; do not commit) --------------
# These directories are kept in the repo as empty folders via .gitkeep, but
# their generated contents are ignored.
models/*
logs/*
*.ckpt
*.csv
!.gitkeep

# ---- Editor / OS noise -------------------------------------------------------
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Keep these (un-ignore important tracked files) -------------------------
# Example configs are SOURCE, not output -> make sure they are never ignored:
!configs/
!configs/*.yaml
